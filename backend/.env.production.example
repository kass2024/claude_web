APP_NAME="JC Architecture & AI Consulting Inc. API"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
# Public URL of the Laravel app when it lives under the main site, e.g. public_html/api/
APP_URL=https://jcarchitectureaiconsulting.com/api

FRONTEND_URL=https://jcarchitectureaiconsulting.com

# Optional: comma-separated extra browser origins for CORS (e.g. local Next.js)
# FRONTEND_URLS=http://localhost:3000

LOG_CHANNEL=stack
LOG_LEVEL=info

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=jc_consulting
DB_USERNAME=CHANGE_ME
DB_PASSWORD=CHANGE_ME

FILESYSTEM_DISK=local

